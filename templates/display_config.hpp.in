/**
 * @file    display_config.hpp
 * @author  Marvin Smith
 * @date    2026-05-29
 *
 * @brief   Display dimensions — generated by CMake for the active target
 *
 * Do not edit directly. Modify the values in the hardware CMakeLists.txt
 * for your target (data/hardware/<target>/CMakeLists.txt) and re-run CMake.
 */
#pragma once

namespace ovb::hal {

/// Merged display dimensions (full window: LCD + keyboard stacked)
inline constexpr int FULL_WIDTH  { @DISPLAY_FULL_WIDTH@ };
inline constexpr int FULL_HEIGHT { @DISPLAY_FULL_HEIGHT@ };

/// Keyboard section dimensions (inline within main window; 0 if in a separate window)
inline constexpr int KBD_WIDTH   { @DISPLAY_KBD_WIDTH@ };
inline constexpr int KBD_HEIGHT  { @DISPLAY_KBD_HEIGHT@ };

/// Keyboard window dimensions (for targets where keyboard is a separate SDL window)
inline constexpr int KBD_WIN_HEIGHT { @DISPLAY_KBD_WIN_HEIGHT@ };

/// LCD section dimensions (derived)
inline constexpr int LCD_WIDTH  { FULL_WIDTH };
inline constexpr int LCD_HEIGHT { FULL_HEIGHT - KBD_HEIGHT };

/// Math layout preview area (within LCD section)
inline constexpr int PREVIEW_MAX_WIDTH  { @DISPLAY_PREVIEW_MAX_WIDTH@ };
inline constexpr int PREVIEW_MAX_HEIGHT { @DISPLAY_PREVIEW_MAX_HEIGHT@ };
inline constexpr int PREVIEW_OFFSET_Y   { (LCD_HEIGHT - PREVIEW_MAX_HEIGHT) / 2 };

/// Keyboard layout margins and spacing
inline constexpr int KEY_PAD      { @DISPLAY_KEY_PAD@ };       ///< Gap between keys
inline constexpr int KBD_HEADER_H { @DISPLAY_KBD_HEADER_H@ };  ///< Keyboard header bar height
inline constexpr int KBD_MARGIN_L { @DISPLAY_KBD_MARGIN_L@ };  ///< Left margin
inline constexpr int KBD_MARGIN_T { @DISPLAY_KBD_MARGIN_T@ };  ///< Top margin (below header)

/// Font size in pixels for the LCD display
inline constexpr int FONT_SIZE { @DISPLAY_FONT_SIZE@ };

} // namespace ovb::hal
